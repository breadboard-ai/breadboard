{
  "name": "bees",
  "version": "0.1.0",
  "private": true,
  "description": "Bees — agent swarm orchestration framework",
  "scripts": {
    "setup": "wireit",
    "dev": "npm run dev:server & npm run dev:web",
    "dev:clean": "rm -rf hive/tickets hive/logs && npm run dev",
    "dev:box:clean": "rm -rf hive/tickets hive/logs && npm run dev:box",
    "dev:box": ".venv/bin/python -m bees.box",
    "dev:server": ".venv/bin/python -m app.server",
    "dev:web": "cd web && npm run dev",
    "dev:hivetool": "cd hivetool && npm run dev",
    "create-hive": "node scripts/create-hive.mjs",
    "test:python": ".venv/bin/python -m pytest tests/ -v",
    "eval": ".venv/bin/python -m bees.eval"
  },
  "wireit": {
    "setup": {
      "command": "python3 -m venv .venv && PIP_INDEX_URL=https://pypi.org/simple/ .venv/bin/pip install -e ../opal-backend'[local]' -e '.[dev]'",
      "files": [
        "pyproject.toml"
      ],
      "output": []
    }
  }
}
