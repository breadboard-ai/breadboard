{
  "name": "bees",
  "version": "0.1.0",
  "private": true,
  "description": "Bees — agent swarm orchestration framework",
  "scripts": {
    "setup": "wireit",
    "session:start": ".venv/bin/python -m bees.cli",
    "ticket:add": ".venv/bin/python -m bees.add_ticket",
    "ticket:drain": ".venv/bin/python -m bees.drain",
    "ticket:respond": ".venv/bin/python -m bees.respond",
    "playbook:run": ".venv/bin/python -m bees.run_playbook",
    "dev": "npm run dev:server & npm run dev:web",
    "dev:clean": "rm -rf hive && npm run dev",
    "dev:server": ".venv/bin/python -m bees.server",
    "dev:web": "cd web && npm run dev",
    "test:python": ".venv/bin/python -m pytest tests/ -v"
  },
  "wireit": {
    "setup": {
      "command": "python3 -m venv .venv && PIP_INDEX_URL=https://pypi.org/simple/ .venv/bin/pip install -e ../opal-backend'[local]' -e '.[dev]'",
      "files": [
        "pyproject.toml"
      ],
      "output": []
    }
  },
  "dependencies": {
    "esbuild": "^0.27.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
